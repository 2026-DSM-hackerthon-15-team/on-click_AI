INTERNAL_API_KEY=change-me
BACKEND_AUTH_TOKEN=
API_BASE_URL=https://backend.example.com

# Optional. Without a key, the deterministic local tool-selection agent is used.
# AI_PROVIDER may be anthropic or openai.
AI_PROVIDER=anthropic
AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_BASE_URL=
AI_REQUEST_TIMEOUT_SECONDS=45

# Instagram publishing: mock for local tests, meta for Meta Graph API.
INSTAGRAM_PROVIDER=mock
INSTAGRAM_GRAPH_BASE_URL=https://graph.facebook.com
INSTAGRAM_GRAPH_API_VERSION=v23.0
INSTAGRAM_PUBLISH_TIMEOUT_SECONDS=30
