INTERNAL_API_KEY=change-me
BACKEND_AUTH_TOKEN=
API_BASE_URL=https://backend.example.com

# Optional. Without a key, the deterministic local tool-selection agent is used.
# AI_PROVIDER may be anthropic or openai.
AI_PROVIDER=anthropic
AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_BASE_URL=
REQUEST_TIMEOUT_SECONDS=10
AI_REQUEST_TIMEOUT_SECONDS=45

# Structured stdout logs for Docker. Use plain only for local readability.
LOG_LEVEL=INFO
LOG_FORMAT=json

# Instagram publishing: mock for local tests, browser_mcp for Browser MCP.
INSTAGRAM_PROVIDER=mock
BROWSER_MCP_URL=http://browser-mcp:3000/mcp
BROWSER_MCP_TOOL=instagram_publish
INSTAGRAM_PUBLISH_TIMEOUT_SECONDS=30
